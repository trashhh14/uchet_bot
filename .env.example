# Telegram bot token from @BotFather. Do not share it.
BOT_TOKEN=replace_with_your_token
APPROVER_USER_ID=123456789
SPREADSHEET_ID=replace_with_spreadsheet_id

# A separate existing sheet tab for each month: 2026-07, 2026-08, etc.
SHEET_PREFIX=
TIMEZONE=Europe/Moscow
USERNAME_COLUMN=A
UZ_COLUMN=B
RP_COLUMN=C
TOTAL_COLUMN=D
# Numeric ID of the Telegram forum topic to monitor; leave empty to monitor all topics.
TARGET_THREAD_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=google-service-account.json
# Only for cloud hosting: paste the full JSON key as one line into this variable.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# DATA_DIR=/data
